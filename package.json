{
  "name": "@dhumdil-apps/pi-kit",
  "version": "0.1.0",
  "private": true,
  "description": "Vendored Pi extensions and skills maintained by dhumdil-apps.",
  "keywords": [
    "pi-package"
  ],
  "license": "MIT",
  "scripts": {
    "test": "vitest run extensions --passWithNoTests",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.41"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.9.0",
    "vitest": "^3.2.0"
  },
  "overrides": {
    "brace-expansion": "^5.0.7",
    "protobufjs": "^7.6.5"
  },
  "pi": {
    "extensions": [
      "./extensions/extension-preferences/index.ts",
      "./extensions/interrupt-confirmation/index.ts",
      "./extensions/terminal-keys/index.ts",
      "./extensions/agent-workflow/index.ts",
      "./extensions/status-bar/index.ts",
      "./extensions/usage-monitor/index.ts",
      "./extensions/usage-history/index.ts",
      "./extensions/progress-tracker/index.ts",
      "./extensions/agent-status-bridge/index.ts",
      "./extensions/session-dashboard/index.ts"
