{
  "name": "@dhumdil-apps/pi-bundle",
  "version": "0.1.0",
  "private": true,
  "description": "Vendored Pi extensions and skills maintained by dhumdil-apps.",
  "keywords": ["pi-package"],
  "license": "MIT",
  "scripts": {
    "test": "vitest run extensions/plan-mode",
    "typecheck:plan": "tsc --noEmit --target ES2023 --module ESNext --moduleResolution Bundler --allowImportingTsExtensions --skipLibCheck --strict --types node extensions/plan-mode/index.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.41",
    "jiti": "2.7.0",
    "yaml": "2.8.3",
    "@mozilla/readability": "^0.6.0",
    "linkedom": "^0.16.0",
    "p-limit": "^6.1.0",
    "turndown": "^7.2.0",
    "unpdf": "^1.6.2",
    "typebox": "^1.1.36"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/turndown": "^5.0.5",
    "typescript": "^5.9.0",
    "vitest": "^3.2.0"
  },
  "pi": {
    "extensions": [
      "./extensions/extension-settings/index.ts",
      "./extensions/ask-user/index.ts",
      "./extensions/memory/index.ts",
      "./extensions/powerbar/src",
      "./extensions/pi-usage/index.ts",
      "./extensions/usage-extension/index.ts",
      "./extensions/manage-todo-list/index.ts",
      "./extensions/plan-mode/index.ts",
      "./extensions/welcome/index.ts",
      "./extensions/claude-style/index.ts",
      "./extensions/permission-gate/index.ts",
      "./extensions/pi-web-access/index.ts"
    ],
    "skills": [
      "./skills",
      "./extensions/pi-web-access/skills"
    ],
    "prompts": ["./prompts"],
    "themes": ["./themes"]
  }
}
